{
  "name": "@biguxuzz/max",
  "version": "1.1.1",
  "description": "MAX Messenger channel plugin for OpenClaw Gateway",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "author": "biguxuzz (Pavel) <pavel@biguxuzz.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/biguxuzz/openclaw-max-plugin.git"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "max",
    "max-messenger",
    "messenger",
    "gateway",
    "bot",
    "chat"
  ],
  "files": [
    "dist/",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "max",
      "label": "MAX Messenger",
      "selectionLabel": "MAX",
      "docsPath": "/channels/max-messenger",
      "blurb": "Connect OpenClaw to MAX messenger via Bot API. Supports DMs, file attachments, and typing indicators.",
      "order": 80
    },
    "install": {
      "npmSpec": "@biguxuzz/max",
      "localPath": "extensions/max-messenger",
      "defaultChoice": "npm"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
